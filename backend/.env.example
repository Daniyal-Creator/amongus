PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgres://postgres:postgres@localhost:5432/amongus_coder
CORS_ORIGIN=http://localhost:3000

# Optional Redis. If unset, an in-memory fallback is used.
REDIS_URL=

# Ollama AI integration (sabotage suggest, copilot poisoning, post-game review).
#
# OPSI A — Ollama Cloud (gratis, recommended untuk dev tanpa GPU):
#   1. Daftar di https://ollama.com
#   2. Settings → API Keys → create
#   3. Set OLLAMA_BASE_URL=https://ollama.com dan OLLAMA_API_KEY=<paste-key>
#
# OPSI B — Ollama lokal:
#   brew/winget install ollama, lalu `ollama pull qwen2.5-coder:7b`
#   OLLAMA_BASE_URL=http://localhost:11434, OLLAMA_API_KEY kosong.
#
# Dua model berbeda untuk tujuan berbeda:
#   - OLLAMA_MODEL_REVIEW   → dipakai post-game code review (perlu pintar, boleh lambat).
#   - OLLAMA_MODEL_IMPOSTER → dipakai "ask ghost" & "poison copilot" (perlu cepat, hint pendek).
# Kalau salah satu kosong, fallback ke OLLAMA_MODEL.
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=qwen3-coder:480b
OLLAMA_MODEL_REVIEW=qwen3-coder:480b
OLLAMA_MODEL_IMPOSTER=gpt-oss:120b
OLLAMA_API_KEY=

# Public Piston sandbox (https://github.com/engineer-man/piston). Override to use a private instance.
PISTON_BASE_URL=https://emkc.org/api/v2/piston

# Rate limit knobs
AI_RATE_LIMIT_PER_MINUTE=5
CHAT_RATE_LIMIT_PER_10S=10
